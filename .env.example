# Copy this file to .env and fill in the real values.
# .env is gitignored. Do NOT commit it.

# --- GMI Cloud (Inference Engine) ---
# Get from console.gmicloud.ai
GMI_API_KEY=replace-me

# OpenAI-compatible LLM endpoint
GMI_LLM_BASE_URL=https://api.gmi-serving.com/v1
GMI_LLM_MODEL=anthropic/claude-opus-4.6

# Video API (follow-up F1, Pixverse)
GMI_VIDEO_BASE_URL=https://console.gmicloud.ai/api/v1/ie/requestqueue/apikey
GMI_VIDEO_MODEL=Pixverse
# GMI_ORG_ID=

# --- Spectrum / Photon ---
# Get from Photon Project Page
SPECTRUM_PROJECT_ID=replace-me
SPECTRUM_PROJECT_SECRET=replace-me

# --- Obscura ---
OBSCURA_BIN=/usr/local/bin/obscura
OBSCURA_CDP_URL=ws://127.0.0.1:9222

# --- Local server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# --- Agent ---
SERVER_BASE_URL=http://127.0.0.1:8000
